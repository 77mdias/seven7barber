generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  BARBER
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum VoucherType {
  FREE_SERVICE
  DISCOUNT_PERCENTAGE
  DISCOUNT_FIXED
  CASHBACK
}

// Better Auth Models
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  password      String?
  verified      Boolean  @default(false)
  role          Role     @default(CLIENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  appointments       Appointment[]      @relation("ClientAppointments")
  barberJobs         Appointment[]      @relation("BarberAppointments")
  reviews            ServiceHistory[]
  promotions         UserPromotion[]
  loyaltyAccount     LoyaltyAccount?
  waitlistEntries    WaitlistEntry[]
  recurringPatterns  RecurringPattern[]
  locationAdmin      LocationAdmin[]
  favoriteLocationId String?
  favoriteLocation   Location?          @relation("UserFavoriteLocation", fields: [favoriteLocationId], references: [id])
  locationBarbers    LocationBarber[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  duration    Int // in minutes
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments     Appointment[]
  locationServices LocationService[]
}

model Appointment {
  id        String            @id @default(uuid())
  dateTime  DateTime
  status    AppointmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  clientId String
  client   User   @relation("ClientAppointments", fields: [clientId], references: [id])

  barberId String
  barber   User   @relation("BarberAppointments", fields: [barberId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  history ServiceHistory?

  @@index([locationId])
}

model ServiceHistory {
  id        String   @id @default(uuid())
  rating    Int // 1-5
  feedback  String?
  images    String[] // URLs
  createdAt DateTime @default(now())

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Voucher {
  id          String      @id @default(uuid())
  code        String      @unique
  type        VoucherType
  value       Decimal     @db.Decimal(10, 2)
  minServices Int         @default(0)
  expiresAt   DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Promotion {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        VoucherType
  value       Decimal     @db.Decimal(10, 2)
  startDate   DateTime    @default(now())
  endDate     DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users UserPromotion[]
}

model UserPromotion {
  id        String    @id @default(uuid())
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id])

  @@unique([userId, promotionId])
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  REFUNDED
}

// Loyalty Models
enum LoyaltyTier {
  BRONZE
  PRATA
  OURO
  DIAMANTE
  RADIANTE
}

enum LoyaltyTransactionType {
  EARN_APPOINTMENT
  EARN_REVIEW
  EARN_REFERRAL
  EARN_BIRTHDAY
  REDEEM_DISCOUNT
  REDEEM_SERVICE
  EXPIRE
  REVERSAL
  REVERSAL_CONFIRMED
}

model LoyaltyAccount {
  id                String      @id @default(uuid())
  userId            String      @unique
  totalPoints       Int         @default(0)
  conversionPoints  Int         @default(0)
  tierPoints        Int         @default(0)
  currentTier       LoyaltyTier @default(BRONZE)
  birthdayAwardedAt DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([userId])
}

model LoyaltyTransaction {
  id             String                 @id @default(uuid())
  userId         String
  type           LoyaltyTransactionType
  points         Int
  balanceAfter   Int
  idempotencyKey String?
  expiresAt      DateTime?
  metadata       Json?
  createdAt      DateTime               @default(now())

  loyaltyAccount LoyaltyAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([idempotencyKey])
}

model PaymentSession {
  id            String        @id @default(uuid())
  appointmentId String
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  qrCode        String?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([appointmentId])
}

// Waitlist Model
enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
  CANCELLED
}

model WaitlistEntry {
  id            String         @id @default(uuid())
  userId        String
  locationId    String
  serviceId     String
  barberId      String
  preferredDate DateTime
  position      Int
  status        WaitlistStatus @default(WAITING)
  notifiedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])

  @@index([locationId, serviceId, barberId, status])
  @@index([userId])
}

// Recurring Appointment Model
enum RecurrencePattern {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum RecurrenceStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

model RecurringPattern {
  id                   String            @id @default(uuid())
  userId               String
  serviceId            String
  barberId             String
  locationId           String
  pattern              RecurrencePattern
  preferredTime        String // HH:mm
  preferredDay         Int? // For monthly: 1-31
  maxInstances         Int               @default(12)
  currentInstanceCount Int               @default(0)
  noShowCount          Int               @default(0)
  status               RecurrenceStatus  @default(ACTIVE)
  nextRunDate          DateTime?
  lastRunDate          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([barberId])
}

// Multi-Location Models
enum AdminRole {
  LOCATION_ADMIN
  SUPER_ADMIN
}

model Location {
  id           String   @id @default(uuid())
  name         String
  address      String
  city         String
  state        String
  zipCode      String
  phone        String
  email        String?
  timezone     String   @default("America/Sao_Paulo")
  isActive     Boolean  @default(true)
  openingHours Json? // OpeningHours[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admins        LocationAdmin[]
  services      LocationService[]
  barbers       LocationBarber[]
  appointments  Appointment[]
  favoriteUsers User[]            @relation("UserFavoriteLocation")

  @@index([isActive])
}

model LocationService {
  id         String   @id @default(uuid())
  locationId String
  serviceId  String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([locationId, serviceId])
}

model LocationBarber {
  id         String   @id @default(uuid())
  locationId String
  barberId   String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  barber     User     @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([locationId, barberId])
}

model LocationAdmin {
  id         String    @id @default(uuid())
  userId     String
  locationId String
  role       AdminRole
  createdAt  DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([locationId])
}
